{
  "version": 2,
  "builds": [
    {
      "src": "api/tasks.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/tasks.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}